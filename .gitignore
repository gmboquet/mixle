# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints

# C extensions
*.so

# Distribution / packaging
.idea
.Python
build/
develop-eggs/
notes/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

.vscode
# Environments and OS files
.venv/
.DS_Store
.claude/
.worktrees/
.benchmarks/

# Downloaded example datasets
/data/

# Research experiments are developed outside the release repository. Promote reusable code into
# mixle/ with tests and documentation before it enters a release branch.
/experiments/

# audit ledgers + Sphinx build output stay local; the docs source (.rst) is published
docs/_build/
audit/

# generated logo preview / QA renders (checkerboard + dark-mode checks) stay local
*_preview_*.png

# Cython-generated C from .pyx (build artifact)
mixle/engines/_dd_kernels.c
mixle/engines/_bitpacked.c
mixle/engines/_lns_kernel.c

# coverage.py output (local runs and CI's --cov-report=xml artifact upload; never committed)
.coverage
.coverage.*
coverage.xml
htmlcov/

# Benchmark smoke output is local. A full current-release result may be reviewed and committed separately;
# historical pre-0.8 artifacts live under benchmarks/archive/ and are never current release evidence.
benchmarks/results/results_quick.json
benchmarks/*.html
